# LeadSquared API Credentials Configuration
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit the '.env' file to version control.

# IMPORTANT: These environment variables do NOT have the 'VITE_' prefix.
# This prevents Vite from bundling them into the client-side JavaScript,
# keeping them 100% secure inside Vercel's server environment.

# LeadSquared Access Key
LEADSQUARED_ACCESS_KEY=u$rb73a7d6c2afc339a643093a77f048c22

# LeadSquared Secret Key
LEADSQUARED_SECRET_KEY=30112dad4542ca339f1c717521198a1cbda3e623
# API Host Region. Default is India region (api-in21.leadsquared.com).
# Adjust if your LeadSquared account belongs to a different cluster (e.g., api.leadsquared.com).
LEADSQUARED_REGION_HOST=api-in21.leadsquared.com
