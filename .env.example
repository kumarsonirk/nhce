# LeadSquared API Credentials Configuration
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit the '.env' file to version control.

# LeadSquared Access Key
VITE_LEADSQUARED_ACCESS_KEY=your_leadsquared_access_key_here

# LeadSquared Secret Key
VITE_LEADSQUARED_SECRET_KEY=your_leadsquared_secret_key_here

# API Host Region. Default is India region (api-in21.leadsquared.com).
# Adjust if your LeadSquared account belongs to a different cluster (e.g., api.leadsquared.com).
VITE_LEADSQUARED_REGION_HOST=api-in21.leadsquared.com
